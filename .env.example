# Copy this file to .env and fill in the keys you use.
# .env is gitignored — never commit real keys.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Feature flags (D10) — blank/0 = fake, 1/true = real ──────────────────────
# Default all OFF so the app runs end-to-end on fakes. Flip a flag ON only after
# its real module has landed. Registry: ~/Workspaces/output/feature-flags.md.
# Server flags (read by src/agent/flags.ts + container.ts):
REAL_CORPUS=
REAL_EMBEDDER=
REAL_LLM=
REAL_RETRIEVAL=
REAL_PIPELINE=
# UI live-data flag (Next.js client; read in src/app/lib/triageSource.ts, not flags.ts):
NEXT_PUBLIC_TRIAGE_LIVE=
