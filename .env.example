# Copy this file to .env and fill in the keys you use.
# .env is gitignored — never commit real keys.

# Chat and embeddings both go through OpenRouter (OpenAI-compatible) on one key.
OPENROUTER_API_KEY=
# Optional: override the default chat model (OpenRouter id) used by src/agent/llm.
# Default is a flagship that supports json_schema structured output through OpenRouter.
CHAT_MODEL=
